# ---------- Core ----------

# Replit auto-injects DATABASE_URL when you enable the Postgres add-on in the
# sidebar "Database" tool — copy that value here, or (in Replit) leave this
# out entirely and just use Secrets, since Replit sets it for you.
DATABASE_URL=postgresql://user:password@host:port/dbname
# Set to "disable" only for a local Postgres without SSL. Leave unset on Replit.
# PGSSLMODE=disable

# Port Express listens on (Replit sets this automatically; 3000 is the local fallback)
PORT=3000

# Public base URL of this deployment — used to build links in emails
# (invites, password resets, Stripe redirect URLs). On Replit, this is your
# repl's .replit.dev / .replit.app URL, or your custom domain.
APP_URL=https://your-repl-name.replit.app

# Random long string used to sign session JWTs — generate one with
# `openssl rand -hex 32` (or any long random string) and never reuse it
# across environments.
JWT_SECRET=change-me-to-a-long-random-string

# ---------- AI (Claude) ----------

# Get this from console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# Optional overrides — defaults shown
# ANTHROPIC_MODEL=claude-sonnet-5
# COST_PER_MILLION_INPUT_USD=3
# COST_PER_MILLION_OUTPUT_USD=15

# How long (minutes) a directive can sit with no update before the background
# sweeper (server/services/staleTaskSweeper.js) treats it as orphaned by a
# server restart and auto-nudges it. Never applies to Stuck/Error tasks.
# STALE_TASK_THRESHOLD_MINUTES=10

# ---------- Stripe (Section 8 — billing) ----------

# From the Stripe Dashboard -> Developers -> API keys. Use a test-mode key
# (sk_test_...) until you're ready to go live.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
# From Stripe Dashboard -> Developers -> Webhooks -> your endpoint's signing
# secret, after you add https://<your-app-url>/api/billing/webhook as an
# endpoint listening for: checkout.session.completed, customer.subscription.*,
# invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# ---------- Email (Section 13 — transactional notifications) ----------
# If left unset, emails are logged to the console instead of sent — the app
# still runs end-to-end, you just won't get real invite/reset/ticket emails.
# Any standard SMTP provider works (Postmark, Resend SMTP, SendGrid SMTP, or
# Gmail for quick testing).
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# SMTP_FROM="AI Agent Workforce Portal <no-reply@yourdomain.com>"

# Where new-ticket notifications get sent internally (Section 7)
SUPPORT_TEAM_EMAIL=support@stradigi.local
