modules = ["nodejs-20", "web", "postgresql-16"]

run = "npm start"
entrypoint = "server/index.js"

[nix]
channel = "stable-25_05"

[env]
NODE_ENV = "production"

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "npm start"]

[[ports]]
localPort = 3000
externalPort = 80

[workflows]
runButton = "Run"

[[workflows.workflow]]
name = "Run"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"

[userenv]

[userenv.shared]
APP_URL = "https://39276709-49dc-47b7-a760-1bf6079e8074-00-2b0fg5h96489s.picard.replit.dev"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000
